# .env.example — CodeReviewX
# Copy this file to .env and fill in your real values.
# NEVER commit .env to the repository.
# All values here are placeholders only.

# Application
APP_ENV=local

# Backend Java
BACKEND_PORT=8080

# Frontend
VITE_API_BASE_URL=http://localhost:8080

# AI Service
AI_SERVICE_PORT=8000
AI_SERVICE_BASE_URL=http://localhost:8000

# Database
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=codereviewx
MYSQL_USER=codereviewx
MYSQL_PASSWORD=<local-password-if-used>

# GitHub
# Recommended fine-grained token permissions:
# - Contents: read
# - Pull requests: read/write
# - Metadata: read
GITHUB_TOKEN=<your-github-token>
GITHUB_API_BASE_URL=https://api.github.com
GITHUB_TIMEOUT_SECONDS=20
GITHUB_MAX_CHANGED_FILES=50
GITHUB_MAX_DIFF_BYTES=512000
GITHUB_PER_FILE_PATCH_MAX_BYTES=20000

# Xiaomi MiMo (never commit real values)
MIMO_PLANNER_API_KEY=<your-planner-key>
MIMO_EXECUTOR_API_KEY=<your-executor-key>
MIMO_BASE_URL=https://api.xiaomimimo.com/v1
MIMO_MODEL=mimo-v2.5-pro
MIMO_TIMEOUT_SECONDS=60
