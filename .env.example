# .env.example — CodeReviewX
# Copy this file to .env and fill in your real values.
# NEVER commit .env to the repository.
# All values here are placeholders only.

# Application
APP_ENV=local

# Backend Java
BACKEND_PORT=8080

# AI Service
AI_SERVICE_PORT=8000
AI_SERVICE_BASE_URL=http://localhost:8000

# Database
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=codereviewx
MYSQL_USER=codereviewx
MYSQL_PASSWORD=change_me

# GitHub
GITHUB_TOKEN=replace_with_your_github_token

# Xiaomi MiMo (never commit real values)
MIMO_PLANNER_API_KEY=replace_with_your_planner_mimo_api_key
MIMO_EXECUTOR_API_KEY=replace_with_your_executor_mimo_api_key
MIMO_BASE_URL=https://api.xiaomimimo.com/v1
MIMO_MODEL=mimo-v2.5-pro
MIMO_TIMEOUT_SECONDS=60
